# Seele skill 环境变量配置
# 复制此文件为 .env 并按实际路径修改

# cmd skill：允许执行命令的默认工作目录
# 建议设置为项目根目录
CMD_SKILL_DIR=G:\Program\go\Seele

# registry skill：registry.yaml 的路径
REGISTRY_PATH=G:\Program\go\Seele\config_example\registry.yaml

# codegen skill：生成的 skill 代码放置的根目录
# codegen 会在此目录下创建 <skill_name>/main.go
TOOLS_DIR=G:\Program\go\Seele\example_tools